
{
  "title": "ML Monitoring Dashboard",
  "panels": [
    {
      "title": "P95 Latency",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "title": "Request Count",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(request_count_total[1m])"
        }
      ]
    }
  ]
}
